filter(type == "test", condition1 == "critical") |>
select(participant_id, stim1, textColor, condition2, RT, correct) |>
rename(condition = condition2) |>
left_join(
questionnaire |> select(participant_id, native_speaker,
english_years, proficiency,
colour_deficiency),
by = "participant_id"
) |>
filter(colour_deficiency == "No") |>
mutate(
group     = if_else(native_speaker == "Yes", "L1", "L2"),
group     = factor(group, levels = c("L1", "L2")),
condition = factor(condition, levels = c("congruent", "incongruent"))
)
# 排除标准
n_before <- nrow(exp_data)
exp_data_clean <- exp_data |>
filter(correct == 1) |>
filter(RT >= 200, RT <= 2500) |>
group_by(participant_id) |>
filter(abs(RT - mean(RT)) <= 3 * sd(RT)) |>
ungroup() |>
mutate(log_rt = log(RT))
n_after    <- nrow(exp_data_clean)
n_excluded <- n_before - n_after
pct_excluded <- round(n_excluded / n_before * 100, 1)
cat("Trials before exclusion:", n_before, "\n")
cat("Trials after exclusion:", n_after, "\n")
cat("Trials excluded:", n_excluded, "(", pct_excluded, "%)\n")
#| label: plot-data
#| fig-width: 7
#| fig-height: 5
# 图1：RT分布
ggplot(exp_data_clean, aes(x = condition, y = RT, fill = group)) +
geom_violin(alpha = 0.4, position = position_dodge(0.8)) +
geom_boxplot(width = 0.2, position = position_dodge(0.8),
outlier.shape = NA) +
scale_fill_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "RT Distribution by Condition and Group",
x = "Condition", y = "Response Time (ms)", fill = "Group"
) +
theme_minimal()
# 图2：每个被试的干扰效应
stroop_effect <- exp_data_clean |>
group_by(participant_id, group, condition) |>
summarise(mean_rt = mean(RT), .groups = "drop") |>
pivot_wider(names_from = condition, values_from = mean_rt) |>
mutate(stroop_effect = incongruent - congruent)
ggplot(stroop_effect, aes(x = group, y = stroop_effect, colour = group)) +
geom_jitter(width = 0.1, size = 3, alpha = 0.7) +
stat_summary(fun = mean, geom = "crossbar", width = 0.3) +
scale_colour_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "Stroop Interference Effect per Participant",
x = "Group",
y = "Stroop Effect (incongruent − congruent RT, ms)"
) +
theme_minimal()
# 图3：均值 + 误差棒
exp_data_clean |>
group_by(group, condition) |>
summarise(
mean_rt = mean(RT),
se_rt   = sd(RT) / sqrt(n()),
.groups = "drop"
) |>
ggplot(aes(x = condition, y = mean_rt, colour = group, group = group)) +
geom_point(size = 3) +
geom_line() +
geom_errorbar(aes(ymin = mean_rt - se_rt, ymax = mean_rt + se_rt),
width = 0.1) +
scale_colour_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "Mean RT by Condition and Group",
x = "Condition", y = "Mean RT (ms)", colour = "Group"
) +
theme_minimal()
install.packages("brms")
#| label: model
#| cache: true
library(brms)
my_seed <- 9283
stroop_bm <- brm(
RT ~ condition * group +
(1 + condition | participant_id),
family = lognormal,
data = exp_data_clean,
seed = my_seed,
cores = 4,
file = "data/cache/stroop_bm"
)
#| label: read-data
#| message: false
#| warning: false
library(tidyverse)
library(brms)
library(broom.mixed)
# 读取并合并所有CSV文件
data_path <- "data/"
raw_data <- list.files(
path = data_path,
pattern = "*.csv",
full.names = TRUE
) |>
map(\(file) {
d <- read_csv(file, skip = 3, show_col_types = FALSE)
d$participant_id <- basename(file)
d
}) |>
list_rbind()
# 提取问卷数据
questionnaire <- raw_data |>
filter(type == "form") |>
select(participant_id, head, response) |>
pivot_wider(names_from = head, values_from = response) |>
rename(
native_speaker    = `Are you a native speaker of English?`,
english_years     = `How long have you been learning/using English?`,
proficiency       = `How would you rate your English proficiency?`,
colour_deficiency = `Do you have any colour vision deficiency?`
)
# 提取正式实验trials并合并问卷
exp_data <- raw_data |>
filter(type == "test", condition1 == "critical") |>
select(participant_id, stim1, textColor, condition2, RT, correct) |>
rename(condition = condition2) |>
left_join(
questionnaire |> select(participant_id, native_speaker,
english_years, proficiency,
colour_deficiency),
by = "participant_id"
) |>
filter(colour_deficiency == "No") |>
mutate(
group     = if_else(native_speaker == "Yes", "L1", "L2"),
group     = factor(group, levels = c("L1", "L2")),
condition = factor(condition, levels = c("congruent", "incongruent"))
)
# 排除标准
n_before <- nrow(exp_data)
exp_data_clean <- exp_data |>
filter(correct == 1) |>
filter(RT >= 200, RT <= 2500) |>
group_by(participant_id) |>
filter(abs(RT - mean(RT)) <= 3 * sd(RT)) |>
ungroup() |>
mutate(log_rt = log(RT))
n_after    <- nrow(exp_data_clean)
n_excluded <- n_before - n_after
pct_excluded <- round(n_excluded / n_before * 100, 1)
cat("Trials before exclusion:", n_before, "\n")
cat("Trials after exclusion:", n_after, "\n")
cat("Trials excluded:", n_excluded, "(", pct_excluded, "%)\n")
#| label: plot-data
#| fig-width: 7
#| fig-height: 5
# 图1：RT分布
ggplot(exp_data_clean, aes(x = condition, y = RT, fill = group)) +
geom_violin(alpha = 0.4, position = position_dodge(0.8)) +
geom_boxplot(width = 0.2, position = position_dodge(0.8),
outlier.shape = NA) +
scale_fill_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "RT Distribution by Condition and Group",
x = "Condition", y = "Response Time (ms)", fill = "Group"
) +
theme_minimal()
# 图2：每个被试的干扰效应
stroop_effect <- exp_data_clean |>
group_by(participant_id, group, condition) |>
summarise(mean_rt = mean(RT), .groups = "drop") |>
pivot_wider(names_from = condition, values_from = mean_rt) |>
mutate(stroop_effect = incongruent - congruent)
ggplot(stroop_effect, aes(x = group, y = stroop_effect, colour = group)) +
geom_jitter(width = 0.1, size = 3, alpha = 0.7) +
stat_summary(fun = mean, geom = "crossbar", width = 0.3) +
scale_colour_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "Stroop Interference Effect per Participant",
x = "Group",
y = "Stroop Effect (incongruent − congruent RT, ms)"
) +
theme_minimal()
# 图3：均值 + 误差棒
exp_data_clean |>
group_by(group, condition) |>
summarise(
mean_rt = mean(RT),
se_rt   = sd(RT) / sqrt(n()),
.groups = "drop"
) |>
ggplot(aes(x = condition, y = mean_rt, colour = group, group = group)) +
geom_point(size = 3) +
geom_line() +
geom_errorbar(aes(ymin = mean_rt - se_rt, ymax = mean_rt + se_rt),
width = 0.1) +
scale_colour_manual(values = c("L1" = "#3498db", "L2" = "#e74c3c")) +
labs(
title = "Mean RT by Condition and Group",
x = "Condition", y = "Mean RT (ms)", colour = "Group"
) +
theme_minimal()
#| label: summarise-data
exp_data_clean |>
group_by(group, condition) |>
summarise(
n_trials  = n(),
mean_RT   = round(mean(RT), 1),
sd_RT     = round(sd(RT), 1),
median_RT = round(median(RT), 1),
.groups   = "drop"
)
#| label: model
#| cache: true
my_seed <- 9283
stroop_bm <- brm(
RT ~ condition * group +
(1 + condition | participant_id),
family = lognormal,
data = exp_data_clean,
seed = my_seed,
cores = 4,
file = "data/cache/stroop_bm"
)
#| label: model
#| cache: true
my_seed <- 9283
stroop_bm <- brm(
RT ~ condition * group +
(1 + condition | participant_id),
family = lognormal,
data = exp_data_clean,
seed = my_seed,
cores = 4,
file = "data/cache/stroop_bm"
)
#| label: model
#| cache: true
my_seed <- 9283
stroop_bm <- brm(
RT ~ condition * group +
(1 + condition | participant_id),
family = lognormal,
data = exp_data_clean,
seed = my_seed,
cores = 1,
file = "data/cache/stroop_bm"
)
#| label: model-summary
summary(stroop_bm, prob = 0.9)
#| label: model-fixef
# 固定效应系数及90% CrI
fixef(stroop_bm, probs = c(0.05, 0.95)) |> round(2)
#| label: model-conditional-effects
# 可视化预测值
conditional_effects(stroop_bm, effects = "condition:group")
#| label: model-draws
# 手动计算L2组的干扰效应（参考课程slides第26页）
stroop_draws <- as_draws_df(stroop_bm) |>
mutate(
# L1组的干扰效应
stroop_L1 = b_conditionincongruent,
# L2组的干扰效应 = 主效应 + 交互项
stroop_L2 = b_conditionincongruent +
`b_conditionincongruent:groupL2`
)
# 报告两组干扰效应的90% CrI
quantile(stroop_draws$stroop_L1, probs = c(0.05, 0.5, 0.95)) |> round(2)
quantile(stroop_draws$stroop_L2, probs = c(0.05, 0.5, 0.95)) |> round(2)
#| label: model-plot
# 模型诊断（chain mixing等）
plot(stroop_bm)
